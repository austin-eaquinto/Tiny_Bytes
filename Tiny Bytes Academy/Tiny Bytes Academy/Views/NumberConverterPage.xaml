<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TinyBytesAcademy.ViewModels"
             x:Class="Tiny_Bytes_Academy.Views.NumberConverterPage"
             Title="Tiny Bytes Converter">

    <!-- Set the Binding Context to the ViewModel -->
    <ContentPage.BindingContext>
        <vm:NumberConverterViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="30">

            <Label Text="Tiny Bytes Converter" 
                   FontSize="30" 
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />
            <Label Text="Convert between Decimal (Base 10), Binary (Base 2), and Hexadecimal (Base 16)." 
                   TextColor="#6B7280" 
                   HorizontalOptions="Center" />

            <!-- 1. Select Input Base (Replaced Frame with Border) -->
            <Border BackgroundColor="#EEF2FF" 
                    Stroke="#C7D2FE" 
                    Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="1. Select Input Base" 
                           TextColor="#10B981" 
                           FontAttributes="Bold" />

                    <HorizontalStackLayout Spacing="8">
                        <CollectionView ItemsSource="{Binding BaseOptions}" 
                                        SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" 
                                                   ItemSpacing="8" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Button Text="{Binding Label}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NumberConverterViewModel}}, Path=SetInputBaseCommand}"
                                            CommandParameter="{Binding Value}"
                                            FontSize="Small" 
                                            CornerRadius="6"
                                            Padding="10,5"
                                            Style="{StaticResource BaseButtonStyle}" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- 2. Enter Value (Replaced Frame with Border) -->
            <Border BackgroundColor="White" 
                    Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <!-- Applying a light shadow for depth, similar to HasShadow=True -->
                    <Shadow Brush="Gray" 
                            Radius="10" 
                            Opacity="0.2" 
                            Offset="5,5" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding InputBase, StringFormat='2. Enter Value (Base {0})'}" 
                           FontAttributes="Bold" />
                    <Entry Text="{Binding InputValue, Mode=TwoWay}" 
                           Placeholder="e.g., 255 or 11111111 or FF" 
                           FontSize="Large" 
                           FontFamily="Consolas" 
                           Keyboard="Text" />

                    <!-- Error Display -->
                    <Label Text="{Binding ConversionError}" 
                           TextColor="#EF4444" 
                           IsVisible="{Binding IsErrorVisible}" 
                           FontAttributes="Bold" />
                </VerticalStackLayout>
            </Border>

            <!-- 3. Select Output Base (Replaced Frame with Border) -->
            <Border BackgroundColor="#ECFDF5" 
                    Stroke="#C7D2FE" 
                    Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="3. Select Output Base" 
                           TextColor="#10B981" 
                           FontAttributes="Bold" />

                    <HorizontalStackLayout Spacing="8">
                        <CollectionView ItemsSource="{Binding BaseOptions}" 
                                        SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" 
                                                   ItemSpacing="8" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Button Text="{Binding Label}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NumberConverterViewModel}}, Path=SetOutputBaseCommand}"
                                            CommandParameter="{Binding Value}"
                                            FontSize="Small" 
                                            CornerRadius="6"
                                            Padding="10,5"
                                            Style="{StaticResource BaseButtonStyle}" />
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Output Section (Replaced Frame with Border) -->
            <Border BackgroundColor="#1F2937" 
                    Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Gray" 
                            Radius="10" 
                            Opacity="0.2" 
                            Offset="5,5" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding OutputBase, StringFormat='Converted Result (Base {0})'}" 
                           FontSize="Medium" 
 
                           FontAttributes="Bold" />
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" 
                               Text="{Binding ConvertedResult}" 
                               TextColor="#6B7280" 
                               FontSize="20" 
                               FontFamily="Consolas" 
                               LineBreakMode="WordWrap" 
                               VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="Copy" 
                                Command="{Binding CopyToClipboardCommand}" 
                                BackgroundColor="#4F46E5" 
                                TextColor="White" 
                                CornerRadius="6" 
                                WidthRequest="80" />
                    </Grid>

                    <!-- Simplified Copy Message Display (IsVisible should be bound to a boolean property if CopyMessage is used as a temporary notification) -->
                    <Label Text="{Binding CopyMessage}" 
                           TextColor="White" 
                           HorizontalOptions="End" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>