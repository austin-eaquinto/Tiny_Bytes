<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:model="clr-namespace:Tiny_Bytes_Academy.Models"
             xmlns:vm="clr-namespace:Tiny_Bytes_Academy.ViewModels"
             xmlns:conv="clr-namespace:Tiny_Bytes_Academy.Converters"
             x:Class="Tiny_Bytes_Academy.Views.MenuPage"
             x:DataType="vm:MenuPageViewModel"
             Title="Lesson Path">

    <ContentPage.Resources>
        <conv:InverseBooleanConverter x:Key="InverseBoolConverter" />
        <conv:BoolToStatusIconConverter x:Key="StatusIconConverter" />

        <Style x:Key="PathConnectorStyle" TargetType="BoxView">
            <Setter Property="Color" Value="{StaticResource LightSecondaryAccent}" />
            <Setter Property="HeightRequest" Value="10" />
            <Setter Property="WidthRequest" Value="2" />
            <Setter Property="HorizontalOptions" Value="Start" />
            <Setter Property="Margin" Value="24, 0, 0, 0" />
        </Style>

    </ContentPage.Resources>

    <Grid Padding="20" RowDefinitions="Auto,*,Auto">
        <CollectionView Grid.Row="1" ItemsSource="{Binding Lessons}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:LessonInfo">
                    <VerticalStackLayout Spacing="0">

                        <Border Margin="0, 5, 0, 5"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="2"
                                Stroke="{StaticResource LightSecondaryAccent}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource LightSurface}, Dark={StaticResource DarkSurface}}">

                            <Grid ColumnDefinitions="50, *, Auto"
                                  HeightRequest="60"
                                  Padding="5, 0"
                                  IsEnabled="{Binding IsLocked, Converter={StaticResource InverseBoolConverter}}">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer
                                         Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MenuPageViewModel}}, Path=GoToLessonCommand}"
                                         CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>

                                <Label Grid.Column="0"
                                       Text="{Binding IsCompleted, Converter={StaticResource StatusIconConverter}, ConverterParameter='IsCompleted'}"
                                       FontSize="24"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />

                                <Label Grid.Column="1"
                                       Text="{Binding Title}"
                                       VerticalOptions="Center" />

                                <Label Grid.Column="2"
                                       Text="{Binding IsLocked, Converter={StaticResource StatusIconConverter}, ConverterParameter='IsLocked'}"
                                       FontSize="24"
                                       Margin="10, 0"
                                       VerticalOptions="Center"
                                       HorizontalOptions="End"
                                       IsVisible="{Binding IsLocked}" />

                            </Grid>
                        </Border>

                        <BoxView Style="{StaticResource PathConnectorStyle}" 
                                 IsVisible="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=RemainingItemsThreshold, Converter={StaticResource InverseBoolConverter}}" />

                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="2" Text="Number Converter"
                Command="{Binding GotoNumberConverterCommand}"
                VerticalOptions="End"
                HorizontalOptions="End"
                Margin="0, 10, 0, 0" />

    </Grid>
</ContentPage>