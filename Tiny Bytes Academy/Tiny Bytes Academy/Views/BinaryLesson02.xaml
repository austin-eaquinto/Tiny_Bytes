<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Tiny_Bytes_Academy.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Tiny_Bytes_Academy.Views.BinaryLesson02"
             x:DataType="vm:BinaryLesson02ViewModel">

    <Grid RowDefinitions="Auto, *, Auto, Auto" >

        <!-- Lesson number. Top Left -->
        <Border Grid.Row="0"
                Stroke="#00A8F3"
                StrokeThickness="2"
                Background="#FF9F1C"
                Padding="12, 5"
                WidthRequest="180"
                HeightRequest="33"
                VerticalOptions="Start"
                HorizontalOptions="Start">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10"/>
            </Border.StrokeShape>
            <Label x:Name="BinaryLesson1Label" 
                   Text="{Binding LessonTitle}" 
                   TextColor="#1A2238" 
                   FontFamily="CascadiaMono" 
                   FontSize="15" />
        </Border>

        <!-- Lesson content -->
        <Label x:Name="LessonContentLabel"
               Grid.Row="1"
               Text="{Binding CurrentInstruction}"
               FontSize="18"
               VerticalOptions="End"
               HorizontalOptions="Center"
               Margin="20"/>

        <!-- MODIFIED: Changed HorizontalStackLayout to CollectionView -->
        <!-- This will now display 8 bits from the ViewModel's 'Bits' collection -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Bits}"
                        IsVisible="{Binding IsBitVisible}"
                        HorizontalOptions="Center"
                        VerticalOptions="Center">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="5"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:BitViewModel">
                    <Border Stroke="#F4F4F4"
                            StrokeThickness="3"
                            BackgroundColor="white">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="0,0,0,0" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <!-- The Command is now bound to the command on the individual BitViewModel -->
                            <TapGestureRecognizer Command="{Binding ToggleCommand}" />
                        </Border.GestureRecognizers>

                        <Image Source="{Binding BitImageSource}" 
                               Margin="10"
                               HeightRequest="38"
                               WidthRequest="38">
                            <Image.Behaviors>
                                <toolkit:IconTintColorBehavior TintColor="Black" />
                            </Image.Behaviors>
                        </Image>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Next button. Bottom Right -->
        <Button Grid.Row="3"
                x:Name="NextButton"
                Text="{Binding NextButtonText}"
                TextColor="#F4F4F4"
                FontFamily="CascadiaMono"
                SemanticProperties.Hint="Goes to the next lesson item"
                Clicked="OnNextButtonClicked"
                HorizontalOptions="End"
                VerticalOptions="End"
                BackgroundColor="#00A8F3"/>
    </Grid>
</ContentPage>